{
	"name": "work-client",
	"private": true,
	"version": "0.0.24",
	"type": "commonjs",
	"imports": {
		"#public/*": [
			"./public/*"
		],
		"#*": [
			"./src/*"
		]
	},
	"scripts": {
		"dev": "vite --host",
		"build": "tsc && vite build --mode production",
		"lint": "oxlint",
		"preview": "vite preview",
		"build-only": "vite build --mode develop",
		"prettier": "prettier . --write",
		"check-types": "tsc --noemit",
		"check-bundle": "vite-bundle-visualizer -c vite.config.ts",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"prepare": "husky",
		"generate-api-types": "npx env-cmd -f .env.development npx @rtk-query/codegen-openapi work-openapi.config.ts"
	},
	"dependencies": {
		"@ebay/nice-modal-react": "^1.2.13",
